++import { describe, it, expect } from 'vitest';
++import { compile } from '../src/engine/promptjs.js';
++
++// ═══════════════════════════════════════════════════════════════════════════════
++// 2.1a ASYNC/AWAIT IIFE (invisible to developer)
++// ═══════════════════════════════════════════════════════════════════════════════
