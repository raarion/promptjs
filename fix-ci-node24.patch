+ src/lexer/promptjs-lexer.js         |   3 +-
+ src/parser/promptjs-parser.js       | 101 +++++++++-
+ src/resolver/promptjs-resolver.js   |   4 +
+ tests/v0.7-data-fetching.test.js    | 292 ++++++++++++++++++++++++++++
+ 5 files changed, 474 insertions(+), 51 deletions(-)
+ create mode 100644 tests/v0.7-data-fetching.test.js
