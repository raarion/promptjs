---
judul: "Counter Interaktif"
---

Halaman Counter:
  data hitung = 0

  Buat h1: $judul

  Buat paragraf:
    Buat span:
      "Jumlah klik: "

    Saat hitung:
      Buat span:
        hitung

  Buat tombol:
    "Klik aku"
    on_klik = simpan hitung tambah 1 ke hitung

  Buat tombol:
    "Reset"
    on_klik = simpan 0 ke hitung
