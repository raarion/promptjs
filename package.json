{
  "name": "@raarion/prompt-js",
  "version": "1.0.0",
  "description": "PromptJS — a mini-DSL template engine that compiles to vanilla JS with zero dependencies",
  "main": "src/engine/promptjs.js",
  "bin": {
    "pjs": "src/cli/index.js"
  },
  "files": [
    "src/",
    "examples/*.pjs",
    "examples/dashboard-app/**/*.pjs",
    "examples/dashboard-app/README.md",
    "examples/todo-app/**/*.pjs",
    "examples/todo-app/README.md",
    "examples/multi-page/**/*.pjs",
    "docs/",
    "assets/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "dist/"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "mutation": "stryker run",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit -p jsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "node src/cli/index.js build --minify",
    "pjs": "node src/cli/index.js",
    "pages:build": "node scripts/build-pages.js",
    "pages:dev": "node scripts/build-pages.js --watch",
    "prepare": "husky",
    "standalone": "node scripts/build-standalone.js",
    "standalone:watch": "node scripts/build-standalone.js --watch"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "*.{json,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "dsl",
    "template",
    "compiler",
    "indonesian",
    "promptjs",
    "bilingual",
    "frontend",
    "vanilla-js",
    "reactive",
    "dom"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "author": "raarion",
  "homepage": "https://raarion.github.io/promptjs/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raarion/promptjs.git"
  },
  "bugs": {
    "url": "https://github.com/raarion/promptjs/issues"
  },
  "sideEffects": false,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^26.0.1",
    "@vitest/coverage-istanbul": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
