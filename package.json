{
  "name": "promptjs",
  "version": "0.9.0",
  "description": "PromptJS — a mini-DSL template engine that compiles to vanilla JS with zero dependencies",
  "main": "src/engine/promptjs.js",
  "bin": {
    "pjs": "src/cli/index.js"
  },
  "files": [
    "src/",
    "examples/",
    "assets/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit -p jsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "node src/cli/index.js build --minify",
    "pjs": "node src/cli/index.js",
    "pages:build": "node scripts/build-pages.js",
    "pages:dev": "node scripts/build-pages.js --watch",
    "prepare": "husky install"
  },
  "keywords": [
    "dsl",
    "template",
    "compiler",
    "indonesian",
    "promptjs",
    "bilingual",
    "frontend",
    "vanilla-js",
    "reactive",
    "dom"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "license": "MIT",
  "author": "raarion",
  "homepage": "https://raarion.github.io/promptjs/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raarion/promptjs.git"
  },
  "bugs": {
    "url": "https://github.com/raarion/promptjs/issues"
  },
  "sideEffects": false,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.2.11",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
